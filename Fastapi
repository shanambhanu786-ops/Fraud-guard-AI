import os
import time
import requests
from typing import Optional, List
from fastapi import FastAPI, HTTPException, BackgroundTasks
from pydantic import BaseModel, Field
from dotenv import load_dotenv

# Load environment variables for LangSmith
load_dotenv()

# Initialize FastAPI
app = FastAPI(title="FinGuard AI - Default Prediction Model Engine")

# --- Mock LangSmith Tracing Framework ---
def log_to_langsmith(run_name: str, inputs: dict, outputs: dict, error: Optional[str] = None):
    """Simulates real-time LangSmith pipeline tracing & evaluation telemetry."""
    print(f"\n[LANGSMITH TRACE LOGGED] Run: {run_name}")
    print(f"Inputs: {inputs}")
    print(f"Outputs: {outputs}")
    if error:
        print(f"Errors Caught: {error}")

# --- Data Schemas ---
class CreditAnalysisRequest(BaseModel):
    company_name: str
    raw_financial_text: str
    webhook_url: Optional[str] = None

class CreditMemoResponse(BaseModel):
    baseline_dscr: float
    stressed_dscr: float
    cash_runway_months: int
    default_risk_tier: str
    audit_justification: str
    anomalies_found: List[str]

# --- Webhook Background Dispatcher ---
def dispatch_webhook(webhook_url: str, payload: dict):
    if not webhook_url:
        return
    try:
        # Simulate exponential backoff retry mechanism
        time.sleep(1) 
        response = requests.post(webhook_url, json=payload, timeout=5)
        print(f"[WEBHOOK DISPATCHED] Status: {response.status_code} sent to {webhook_url}")
    except Exception as e:
        print(f"[WEBHOOK ERROR] Failed to broadcast payload: {str(e)}")

# --- Core Prompt Engineering & Reverse Auditing Logic ---
def run_finguard_pipeline(data: CreditAnalysisRequest) -> dict:
    start_time = time.time()
    
    # 1. RTF + TCI + Chain-of-Thought Core Prompt Simulation
    # In a real environment, you would invoke: ChatOpenAI() or BedrockChat() here passing these prompts
    inputs_prompt_1 = {
        "role": "Lead Credit Risk Auditor at IDBI Bank",
        "task": "Extract Net Operating Income, compute baseline DSCR, execute a +200 bps interest stress-rate test.",
        "context": data.raw_financial_text
    }
    
    # Simulated execution response outputting structured financial calculations
    simulated_llm_output_1 = {
        "baseline_dscr": 1.75,
        "stressed_dscr": 1.15,
        "cash_runway_months": 8,
        "default_risk_tier": "Medium Risk",
        "audit_justification": "Calculated step-by-step: NOI of $175k / Debt Service of $100k. Stressed scenario drops NOI relative to interest spikes."
    }
    
    log_to_langsmith("Default_Prediction_Engine", inputs=inputs_prompt_1, outputs=simulated_llm_output_1)

    # 2. Reverse Engineering & Mistake Finding Audit Prompt Simulation
    inputs_prompt_2 = {
        "role": "Adversarial Financial Forensic Agent",
        "task": "Derive raw financials backwards from the generated memo and verify mathematical balance alignments.",
        "memo_to_verify": simulated_llm_output_1,
        "ground_truth": data.raw_financial_text
    }
    
    # Check if raw text contains internal discrepancy indicators to mimic mistake finding
    anomalies = []
    if "mismatch" in data.raw_financial_text.lower() or "error" in data.raw_financial_text.lower():
        anomalies.append("Double-Entry Anomaly Flag: Total reported liabilities do not properly rebalance against net assets.")
    
    simulated_llm_output_2 = {
        "validation_passed": len(anomalies) == 0,
        "anomalies_detected": anomalies
    }
    
    log_to_langsmith("Reverse_Engineering_Audit_Engine", inputs=inputs_prompt_2, outputs=simulated_llm_output_2)
    
    latency = time.time() - start_time
    print(f"[BENCHMARK] Pipeline completed in {latency:.2f} seconds.")

    # Package unified response payload
    final_result = {**simulated_llm_output_1, "anomalies_found": anomalies}
    return final_result

# --- REST Endpoints ---
@app.post("/api/v1/analyze-credit", response_model=CreditMemoResponse)
async def analyze_credit(request: CreditAnalysisRequest, background_tasks: BackgroundTasks):
    try:
        result = run_finguard_pipeline(request)
        
        # Trigger event-driven webhook dispatch asynchronously if URL provided
        if request.webhook_url:
            background_tasks.add_task(dispatch_webhook, request.webhook_url, {"event": "CREDIT_AUDIT_COMPLETED", "data": result})
            
        return result
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
